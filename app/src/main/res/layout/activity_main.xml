<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        app:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:popupTheme="@style/ThemeOverlay.MaterialComponents.Light">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ॐ"
                    android:textSize="28sp"
                    android:textColor="@color/accent"
                    android:paddingEnd="8dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="10"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_app_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hindu Panchang 2026"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tv_vikram_samvat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vikram Samvat 2083"
                        android:textColor="@color/accent"
                        android:textSize="11sp"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/iv_language"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_language"
                    android:padding="8dp"
                    android:tint="@color/white"
                    android:onClick="onOptionsItemSelected"/>

            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>

        <!-- Month navigation header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/primary_dark"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <ImageButton
                android:id="@+id/btn_prev_month"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_month_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="January 2026"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_hindu_month"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Paush"
                    android:textColor="@color/accent"
                    android:textSize="12sp"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_next_month"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_forward"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"/>

        </LinearLayout>

        <!-- Day of Week headers -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:background="@color/surface_variant">

            <TextView android:id="@+id/tv_day_sun"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center"
                android:text="Sun" android:textSize="12sp"
                android:textColor="@color/sunday_color" android:textStyle="bold"/>
            <TextView android:id="@+id/tv_day_mon"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center"
                android:text="Mon" android:textSize="12sp" android:textColor="@color/text_secondary"/>
            <TextView android:id="@+id/tv_day_tue"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center"
                android:text="Tue" android:textSize="12sp" android:textColor="@color/text_secondary"/>
            <TextView android:id="@+id/tv_day_wed"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center"
                android:text="Wed" android:textSize="12sp" android:textColor="@color/text_secondary"/>
            <TextView android:id="@+id/tv_day_thu"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center"
                android:text="Thu" android:textSize="12sp" android:textColor="@color/text_secondary"/>
            <TextView android:id="@+id/tv_day_fri"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center"
                android:text="Fri" android:textSize="12sp" android:textColor="@color/text_secondary"/>
            <TextView android:id="@+id/tv_day_sat"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center"
                android:text="Sat" android:textSize="12sp"
                android:textColor="@color/saturday_color" android:textStyle="bold"/>

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Calendar Grid -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_calendar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface"
                android:nestedScrollingEnabled="false"
                android:padding="4dp"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@color/surface_variant"/>

            <!-- Events Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Section Title -->
                <TextView
                    android:id="@+id/tv_events_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upcoming Events"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:layout_marginBottom="12dp"/>

                <!-- Filter Buttons -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_filter_all"
                            style="@style/EventFilterButton"
                            android:layout_marginEnd="8dp"
                            android:text="All"
                            android:selected="true"/>

                        <Button
                            android:id="@+id/btn_filter_festival"
                            style="@style/EventFilterButton"
                            android:layout_marginEnd="8dp"
                            android:text="Festivals"/>

                        <Button
                            android:id="@+id/btn_filter_vrat"
                            style="@style/EventFilterButton"
                            android:layout_marginEnd="8dp"
                            android:text="Vrat"/>

                        <Button
                            android:id="@+id/btn_filter_ekadashi"
                            style="@style/EventFilterButton"
                            android:text="Ekadashi"/>

                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Events List -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_events"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>

            </LinearLayout>

            <!-- Footer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp"
                android:background="@color/primary">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ॐ नमः शिवाय"
                    android:textColor="@color/accent"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hindu Panchang Calendar 2026"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
